# --- LLM backend ---
# Por defecto el agente usa Ollama local. Si querés cambiar el modelo o el host:
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Fallback DeepSeek (opcional, todavía no requerido por el MVP) ---
# Si en el futuro querés usar DeepSeek vía su API, descomentá y completá:
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
